# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=vadim_bogachev
DB_PASSWORD=PASTE_YOUR_LOCAL_DB_PASSWORD_HERE

# Logging
LOG_LEVEL=INFO
LOG_TO_STDOUT=true
LOG_TO_FILE=true
LOG_DIR=./logs
LOG_FILENAME=agent4k.log
LOG_ERROR_FILENAME=agent4k-error.log
LOG_ROTATION_WHEN=midnight
LOG_BACKUP_COUNT=14
AUDIT_LOGS_TO_DB=true
RUNTIME_LOGS_TO_DB=false

# App / Auth
APP_BASE_URL=https://your-ngrok-url.ngrok-free.dev
AUTH_MAGIC_LINK_TTL_MINUTES=15
AUTH_MAGIC_LINK_DEV_MODE=true
AUTH_MAGIC_LINK_FROM_EMAIL=no-reply@agent4k.local
AUTH_MAGIC_LINK_SUBJECT=Вход в 4K Ассистент
EMAIL_PROVIDER=
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

# Admin access by email
# SUPERADMIN_EMAILS sees all organizations.
# ORG_* format: org-code:value1,value2;other-org:value3
SUPERADMIN_EMAILS=
ORG_NAMES=pilot:Пилотная организация
ORG_ADMIN_EMAILS=pilot:admin@example.com
ORG_MEMBER_DOMAINS=pilot:example.com

# LLM provider
DEEPSEEK_API_KEYS=PASTE_LOCAL_KEY_1_HERE,PASTE_LOCAL_KEY_2_HERE
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MBTI add-on
MBTI_ENABLED=true
MBTI_FAISS_INDEX_DIR=/Users/vadim_bogachev/Desktop/mbti/mbti_rag/data/faiss
MBTI_TOP_K=5
MBTI_FOLLOWUP_MODE=strict
MBTI_FOLLOWUP_MAX_PER_CASE=2
MBTI_FOLLOWUP_SCORE_THRESHOLD=60
MBTI_REFINEMENT_TARGET_CONFIDENCE=75
MBTI_REFINEMENT_MAX_QUESTIONS=6

# External occupation knowledge
ESCO_API_ENABLED=true
ESCO_API_BASE_URL=https://ec.europa.eu/esco/api
ESCO_API_VERSION=v1.2.0
ESCO_API_LANGUAGE=en

# Dev / previews
AGENT4K_ENABLE_SCREEN_PREVIEWS=0
