# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=change_me

# Logging
LOG_LEVEL=INFO
LOG_TO_STDOUT=true
LOG_TO_FILE=false
LOG_DIR=./logs
LOG_FILENAME=agent4k.log
LOG_ERROR_FILENAME=agent4k-error.log
LOG_ROTATION_WHEN=midnight
LOG_BACKUP_COUNT=14
AUDIT_LOGS_TO_DB=true
RUNTIME_LOGS_TO_DB=false
APP_BASE_URL=http://127.0.0.1:8000
AUTH_MAGIC_LINK_TTL_MINUTES=15
AUTH_MAGIC_LINK_DEV_MODE=true
AUTH_MAGIC_LINK_FROM_EMAIL=no-reply@agent4k.local
AUTH_MAGIC_LINK_SUBJECT=Вход в 4K Ассистент
EMAIL_PROVIDER=
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

# LLM provider
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MBTI add-on
MBTI_ENABLED=false
MBTI_FAISS_INDEX_DIR=
MBTI_TOP_K=5
MBTI_FOLLOWUP_MODE=assist
MBTI_FOLLOWUP_MAX_PER_CASE=2
MBTI_FOLLOWUP_SCORE_THRESHOLD=60

# External occupation knowledge
ESCO_API_ENABLED=true
ESCO_API_BASE_URL=https://ec.europa.eu/esco/api
ESCO_API_VERSION=v1.2.0
ESCO_API_LANGUAGE=en

# Deployment notes
# 1. Copy this file to .env on the target server.
# 2. Replace DB_* values with the real PostgreSQL credentials.
# 3. Replace DEEPSEEK_API_KEY with a valid API key.
# 4. Enable LOG_TO_FILE=true if you want daily rotating application logs on disk.
# 5. Run: pip install -r requirements.txt
# 6. Start the app: uvicorn main:app --host 0.0.0.0 --port 8000
